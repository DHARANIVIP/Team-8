# =============================================================================
# .gitattributes — Normalize line endings across Windows/macOS/Linux
# =============================================================================

# Default: normalize all text files to LF on commit
* text=auto eol=lf

# Explicitly LF for these file types
*.js        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.env       text eol=lf
*.env.*     text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf
*.sql       text eol=lf
*.sh        text eol=lf

# Binary — never touch line endings
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.otf       binary
*.mp4       binary
*.webp      binary
*.pdf       binary
*.zip       binary
