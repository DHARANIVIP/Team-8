# =============================================================================
# Mastermind - Career Pathway Guidance System
# Root .gitignore — Monorepo (covers apps/frontend & apps/backend)
# =============================================================================

# -----------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------
node_modules/
**/node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# -----------------------------------------------------------------------
# Environment & Secrets  ⚠️  NEVER commit these
# -----------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example
apps/backend/.env
apps/frontend/.env.local
apps/frontend/.env.*.local
apps/.env.local.example

# -----------------------------------------------------------------------
# Next.js (Frontend)
# -----------------------------------------------------------------------
apps/frontend/.next/
apps/frontend/out/
apps/frontend/build/
apps/frontend/.vercel

# -----------------------------------------------------------------------
# Build / Dist output
# -----------------------------------------------------------------------
dist/
build/
out/

# -----------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/

# -----------------------------------------------------------------------
# OS Artifacts
# -----------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------
# Editor / IDE
# -----------------------------------------------------------------------
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# -----------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts

# -----------------------------------------------------------------------
# Testing & Coverage
# -----------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# -----------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------
.cache/
.turbo/
*.pem
